#!/usr/bin/env bash
#MISE description="Search across accessible knowledge providers"
#USAGE arg "[args]..." var=#true help="Provider, options, and query"
#USAGE example "search all obfuscation" header="Search all configured providers"
#USAGE example "search notes --limit 3 obfuscation" header="Search local notes"
#USAGE example "search web --limit 5 mise tasks" header="Search the web"
#USAGE example "search issues --repo KnickKnackLabs/shimmer model" header="Search GitHub issues"
set -euo pipefail

source "$MISE_CONFIG_ROOT/lib/common.sh"
source "$MISE_CONFIG_ROOT/lib/search.sh"

command="${1:-}"
if [ -n "$command" ]; then
  shift
fi

case "$command" in
  all)
    search_all "$@"
    ;;
  notes)
    search_notes "$@"
    ;;
  web)
    search_web "$@"
    ;;
  issues)
    search_github issues issues "$@"
    ;;
  prs)
    search_github prs prs "$@"
    ;;
  code)
    search_github code code "$@"
    ;;
  providers|provider:list|source:list)
    search_providers
    ;;
  help|--help|-h|'')
    search_print_usage
    ;;
  *)
    echo "search: unknown provider or command '$command'" >&2
    echo "search: use 'search all \"$command $*\"' for a blended search" >&2
    echo "search: run 'search providers' to inspect provider configuration" >&2
    exit 1
    ;;
esac
